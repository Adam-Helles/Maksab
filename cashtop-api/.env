# Database — استخدم PostgreSQL للإنتاج، SQLite للتطوير
DATABASE_URL=sqlite:///./cashtop.db
# DATABASE_URL=postgresql://user:password@localhost:5432/cashtop_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_NAME=CashTop
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Admin seed
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cashtop.com
ADMIN_PASSWORD=Admin@1234
