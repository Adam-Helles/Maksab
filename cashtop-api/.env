# ─── Database ────────────────────────────────────────────
# استخدم PostgreSQL للإنتاج، SQLite للتطوير المحلي
DATABASE_URL=sqlite:///./cashtop.db
# DATABASE_URL=postgresql://user:password@localhost:5432/cashtop_db

# ─── JWT ─────────────────────────────────────────────────
# ⚠️ PRODUCTION: يجب تغيير هذه القيمة من Render Environment Variables
# لا تضع SECRET_KEY الحقيقي هنا مباشرة — استخدم متغيرات بيئة Render
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Rate Limiting ────────────────────────────────────────
LOGIN_RATE_LIMIT=5/minute
SIGNUP_RATE_LIMIT=3/hour

# ─── App ─────────────────────────────────────────────────
APP_NAME=CashTop
APP_VERSION=1.0.0
# ⚠️ PRODUCTION: يجب أن يكون DEBUG=False في الإنتاج
DEBUG=False
# أضف هنا URL تطبيقك الموبايل (Expo Go / EAS Build)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── Admin Seed ──────────────────────────────────────────
# ⚠️ PRODUCTION: يجب تغيير هذه القيم من Render Environment Variables
# لا تحتفظ ببيانات المدير الافتراضية هنا في الإنتاج
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cashtop.com
ADMIN_PASSWORD=Admin@1234
